// For devcontainer.json docs, see:
// - https://aka.ms/devcontainer.json
// Resources:
// - https://containers.dev/guide/dockerfile
// - https://github.com/devcontainers/images/tree/main/src/javascript-node
// - https://github.com/devcontainers/images/tree/main/src/typescript-node
{
	"name": "claude-workspace",

	"dockerComposeFile": "./compose.yml",
	"service": "workspace",
	"workspaceFolder": "/workspace",

	// More info: https://containers.dev/features
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": "true",
			"username": "eng-user",
			"upgradePackages": "true"
		},

		// docker-in-docker (instead of docker-outside-of-docker) for better isolation
		// - DooD provides access to the hosts' docker socket, which by default is run with root
		// - DinD does require `--privileged` access, but this is partly mitigated by using `nono`
		// - Another option is to do DinD but using `sysbox` runtime so `--privileged` is not needed
		"ghcr.io/devcontainers/features/docker-in-docker:3": {
			"moby": false // moby no longer included since debian:trixie
		}
	},

	// Configure tool-specific properties
	"customizations": {
		"vscode": {
			// Add the IDs of extensions you want installed when the container is created
			"extensions": [
				// NOTE: Not including `anthropic.claude-code` extension since:
				// 1. This dev-container is run in privileged mode due to docker-in-docker
				// 2. There does't seem to be a way to lock down the extension version
				//
				// Currently the only other solution is to use sysbox-runc runtime for docker
				// - https://github.com/nestybox/sysbox/blob/master/docs/user-guide/deploy.md

				// "anthropic.claude-code",

				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode"
			]
		},
		"settings": {
			"formatOnSave": true,
			"defaultFormatter": "esbenp.prettier-vscode"
		}
	},

	"mounts": [
		// Volume to preserve command history
		"source=cmdhistory-${devcontainerId},target=/cmdhistory,type=volume",
		// Volume to preserve user-scope config
		// Comment this out to use claude config from own local machine as defined by `compose.claude.yml`
		"source=claude-config-${devcontainerId},target=/home/eng-user/.claude-volume,type=volume"
	],
	"containerEnv": {
		// Workaround to prevent needing to reauth on container rebuild
		// https://github.com/anthropics/claude-code/issues/1736#issuecomment-3113994138
		"CLAUDE_CONFIG_DIR": "/home/eng-user/.claude"
	},

	// Command to run after the container is created for the first time
	"postCreateCommand": "nono --version; claude -v;",
	// Command to run every time the container is started
	"postStartCommand": "./.devcontainer/utils/post-start.sh",

	// Set `remoteUser` to `root` to connect as root instead
	// More info: https://aka.ms/dev-containers-non-root
	"remoteUser": "eng-user"
}
